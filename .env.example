# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/skinvise
# For development/testing, use SQLite:
# DATABASE_URL=sqlite+aiosqlite:///./skinvise.db

# App Settings
APP_NAME=SkinVise AI Engine
APP_VERSION=1.0.0
DEBUG=true

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Image Validation
MAX_IMAGE_SIZE_MB=10
MIN_BRIGHTNESS=40
MAX_BRIGHTNESS=220
MIN_SHARPNESS=50
